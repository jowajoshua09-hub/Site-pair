"use client";
import { useState } from "react";
import axios from "axios";

const API = "https://wa-peak-1.onrender.com";

export default function Home() {
  const [num, setNum] = useState("");
  const [code, setCode] = useState("");
  const [loading, setLoading] = useState(false);
  const [err, setErr] = useState("");

  const clean = (v:string) => {
    let x = v.replace(/\D/g,"");
    if(x.startsWith("00")) x=x.slice(2);
    if(x.startsWith("0") && x.length>=10) x="263"+x.slice(1);
    return x;
  }

  const pair = async () => {
    const n = clean(num);
    if(n.length<10){ setErr("Enter valid number like 263783633309"); return; }
    setLoading(true); setErr(""); setCode("");
    try{
      const {data} = await axios.get(`${API}/pair`,{params:{number:n}});
      setCode(data.code || data.pairCode);
    }catch(e:any){ setErr(e.response?.data?.error || "Failed, try again"); }
    setLoading(false);
  }

  return (
    <div className="min-h-screen flex items-center justify-center p-4 bg-gradient-to-br from-zinc-950 to-black">
      <div className="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-2xl p-6 shadow-2xl">
        <h1 className="text-2xl font-bold">⚡ PEAK-MD PAIR</h1>
        <p className="text-zinc-400 text-sm mt-1">Link your WhatsApp in 20s • Public</p>

        <input value={num} onChange={e=>setNum(e.target.value)} placeholder="263783633309"
          className="w-full mt-6 bg-black border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-white" />

        <button onClick={pair} disabled={loading}
          className="w-full mt-4 bg-white text-black font-bold py-3 rounded-xl hover:bg-zinc-200 disabled:opacity-50">
          {loading? "Generating..." : "Get Pair Code"}
        </button>

        {code && (
          <div className="mt-6 bg-black border border-green-900 rounded-xl p-4 text-center">
            <p className="text-xs text-zinc-400">YOUR CODE</p>
            <p className="text-3xl font-mono font-bold tracking-widest mt-1">{code.slice(0,4)}-{code.slice(4)}</p>
            <p className="text-xs text-green-400 mt-2">Expires in 60s • WhatsApp → Linked Devices → Link with phone number</p>
            <button onClick={()=>navigator.clipboard.writeText(code)} className="mt-3 text-sm underline">Copy Code</button>
          </div>
        )}
        {err && <p className="mt-4 text-red-400 text-sm text-center">{err}</p>}

        <div className="mt-6 flex gap-2">
          <a href="https://t.me/Illstar372bot" className="flex-1 text-center bg-zinc-800 py-2 rounded-lg text-sm">Telegram Bot</a>
          <a href="https://api-blacknode.zone.id" className="flex-1 text-center bg-zinc-800 py-2 rounded-lg text-sm">API Docs</a>
        </div>
        <p className="text-[11px] text-zinc-600 text-center mt-6">Built by {process.env.NEXT_PUBLIC_OWNER || "StarDev-il"} • Powered by BlackNode</p>
      </div>
    </div>
  )
}